PORT=3001
DB_PATH=./data/app.db
CORS_ORIGIN=http://localhost:5173

LLM_DEFAULT_MODEL=claude-opus-4-6
LLM_MAX_TOKENS=2000

# Claude / Anthropic-compatible relay
ANTHROPIC_BASE_URL=https://ace2.ezclaude.com
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=claude-opus-4-6
CLAUDE_MODELS=claude-opus-4-6,claude-sonnet-4-5
ANTHROPIC_VERSION=2023-06-01

# DeepSeek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro,deepseek-chat

# Kimi / Moonshot
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_API_KEY=
KIMI_DEFAULT_MODEL=kimi-k2.5
KIMI_MODELS=kimi-k2.5,kimi-k2-turbo-preview,kimi-k2-thinking

# GLM / Zhipu
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZAI_API_KEY=
GLM_DEFAULT_MODEL=glm-5.1
GLM_MODELS=glm-5.1,glm-5,glm-4.5-air

# Tavily Search
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_MAX_RESULTS=5
TAVILY_TIMEOUT_MS=15000
TAVILY_INCLUDE_RAW_CONTENT=false

# Knowledge Base
KNOWLEDGE_MAX_UPLOAD_BYTES=2097152
KNOWLEDGE_MAX_RESULTS=10
KNOWLEDGE_PREVIEW_CHARS=300
KNOWLEDGE_CONTENT_CHARS=4000

# Legacy single-provider fallback
LLM_PROVIDER=
LLM_BASE_URL=
LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_COMPAT_MODELS=
